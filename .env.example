# DeepSeek API 配置
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_MODEL=deepseek-chat

# JWT 密钥（至少 32 字节，用 python -c "import secrets; print(secrets.token_hex(32))" 生成）
SECRET_KEY=生成至少32字节的随机字符串填在这里
ACCESS_TOKEN_TTL_SECONDS=86400

# 管理员密钥（访问 /admin 后台和 /api/admin/* 接口用）
ADMIN_KEY=换一个你自己的管理员密钥

# 开发模式：true = 购买直接到账，false = 手动确认
MOCK_PAYMENTS_ENABLED=false
